# ── Anthropic ────────────────────────────────────────────────────────────────
# Required for AI-powered transcript analysis.
# Without this, analysis falls back to the rule-based local analyzer.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────
# Anthropic model used for transcript analysis (default: claude-haiku-4-5-20251001)
# TRANSCRIPT_ANALYSIS_MODEL=claude-opus-4-6

# Override storage directory for analysis results (default: .frameai/analyses/)
# FRAMEAI_STORAGE_DIR=/var/data/frameai/analyses

# ── Authentication ────────────────────────────────────────────────────────────
# Secret for signing JWT tokens (change in production!)
JWT_SECRET=your-secret-key-here-change-in-production

# ── Google OAuth (Gmail Integration) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/gmail/callback
